{
    "task": "traffic_state_pred",
    "model": "TIDAL",
    "dataset": "HaikouTaxi20x20",
    "hid_dim": 96,
    "d_out": 1024,
    "n_heads": 4,
    "M": 12,
    "num_layers": 4,
    "patch_size": 2,
    "att_type": "proxy",
    "query_cross_time": 1,
    "return_att": 0,
    "prob_factor": 5,
    "norm_flag": "first",
    "enc_dropout": 0.2,
    "att_dropout": 0.2,
    "emb_dropout": 0.15,
    "te_emb_dropout": 0.15,
    "se_emb_dropout": 0.15,
    "tle_emb_dropout": 0.15,
    "drop_path_rate": 0.1,
    "activation_data": "gelu",
    "activation_enc": "gelu",
    "activation_dec": "gelu",
    "scaler": "standard",
    "load_external": true,
    "normal_external": false,
    "ext_scaler": "none",
    "add_time_in_day": true,
    "add_day_in_week": true,
    "slice_size_per_day": 48,
    "input_window": 24,
    "output_window": 3,
    "output_dim": 2,
    "batch_size": 32,
    "seed": 3407,
    "max_epoch": 200,
    "learner": "adamw",
    "learning_rate": 0.001,
    "weight_decay": 0.001,
    "lr_decay": true,
    "lr_scheduler": "cosinelr",
    "lr_eta_min": 0,
    "lr_decay_ratio": 0.1,
    "lr_warmup_epoch": 10,
    "lr_warmup_init": 1e-06,
    "clip_grad_norm": true,
    "max_grad_norm": 5,
    "use_early_stop": true,
    "patience": 25,
    "huber_delta": 2,
    "set_loss": "masked_mae",
    "metrics": [
        "MAE",
        "RMSE",
        "MAPE"
    ],
    "gpu": true,
    "gpu_id": [
        0
    ],
    "train": true,
    "cache_dataset": true,
    "num_workers": 0,
    "pad_with_last_sample": true,
    "train_rate": 0.7,
    "eval_rate": 0.1
}