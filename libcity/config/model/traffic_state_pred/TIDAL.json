{
    "hid_dim": 64,
    "d_out": 1024,
    "n_heads": 2,
    "M": 8,
    "num_layers": 1,
    "patch_size": 2,
    "att_type": "proxy",
    "query_cross_time": 1,
    "return_att": 0,
    "prob_factor": 5,
    "norm_flag": "first",
    "enc_dropout": 0.1,
    "att_dropout": 0.1,
    "emb_dropout": 0.1,
    "te_emb_dropout": 0.1,
    "se_emb_dropout": 0.1,
    "tle_emb_dropout": 0.1,
    "activation_data": "gelu",
    "activation_enc": "gelu",
    "activation_dec": "gelu",
    "scaler": "standard",
    "load_external": true,
    "normal_external": false,
    "ext_scaler": "none",
    "add_time_in_day": true,
    "add_day_in_week": true,
    "slice_size_per_day": 288,
    "batch_size": 32,
    "seed": 0,
    "max_epoch": 100,
    "learner": "adamw",
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "lr_decay": true,
    "lr_scheduler": "cosinelr",
    "lr_eta_min": 0,
    "lr_decay_ratio": 0.1,
    "lr_warmup_epoch": 5,
    "lr_warmup_init": 1e-06,
    "clip_grad_norm": true,
    "max_grad_norm": 5,
    "use_early_stop": false,
    "patience": 20,
    "huber_delta": 2,
    "set_loss": "huber",
    "metrics": [
        "MAE",
        "RMSE",
        "MAPE"
    ]
}